# Copy this file to .env.local for local `vercel dev` testing.
# In production, set these in Vercel → Project Settings → Environment Variables instead.

# Server-only — used by /api/_lib/supabaseAdmin.js. NEVER prefix with a public/client marker,
# never reference from anything under /public.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Server-only — used by /api/copilot/chat.js (AI Copilot page). Get one at
# console.anthropic.com. Without this set, every other page works fine —
# only the AI Copilot chat will return a clear "not configured yet" error.
ANTHROPIC_API_KEY=

# Used by /api/invites/index.js to build the invite-email redirect link.
SITE_URL=http://localhost:3000

# NOTE: the Supabase *anon* key is intentionally NOT an env var — it's safe to expose to the
# browser by design, so it's hardcoded directly in public/shared/supabase-client.js instead
# (see that file's TODO comment). This keeps the static frontend build-step-free.
